<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="1000.0" spacing="40.0" style="-fx-background-color: #fcebd5;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.fiuba.algo3.controlador.FinDePartidaControlador">

    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label text="🏆 ¡Fin de la partida! 🏆">
        <font>
            <Font name="System Bold" size="48.0" />
        </font>
    </Label>

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER" maxHeight="250.0" maxWidth="800.0" prefHeight="250.0" prefWidth="800.0" style="-fx-background-color: #4a6572; -fx-border-color: black; -fx-border-width: 3; -fx-background-radius: 5; -fx-border-radius: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 10, 0, 5, 5);">

        <Label fx:id="lblParte1" text="¡LA ">
            <font><Font name="System Bold" size="36.0" /></font>
        </Label>
        <Label fx:id="lblParte2" text="MAFIA" textFill="#cc0000">
            <font><Font name="System Bold" size="36.0" /></font>
        </Label>
        <Label fx:id="lblParte3" text=" DOMINA LA CIUDAD!">
            <font><Font name="System Bold" size="36.0" /></font>
        </Label>

    </HBox>

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="BOTTOM_LEFT" spacing="20.0">
        <Button mnemonicParsing="false" onAction="#manejarBotonSalir" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #fca311; -fx-border-color: black; -fx-border-width: 2;" text="SALIR">
            <font><Font name="System Bold" size="16.0" /></font>
        </Button>

        <Button mnemonicParsing="false" onAction="#manejarBotonRevelar" prefHeight="40.0" prefWidth="250.0" style="-fx-background-color: #fca311; -fx-border-color: black; -fx-border-width: 2;" text="REVELAR JUGADORES">
            <font><Font name="System Bold" size="16.0" /></font>
        </Button>

        <Region HBox.hgrow="ALWAYS" />

        <ImageView fitHeight="60.0" fitWidth="120.0" preserveRatio="true">
            <image>
                <Image url="@/imagenes/logo_fiuba.png" />
            </image>
        </ImageView>
    </HBox>
</VBox>