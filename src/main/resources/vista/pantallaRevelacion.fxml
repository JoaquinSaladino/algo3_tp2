<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="1000.0" spacing="20.0" style="-fx-background-color: #fcebd5;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.fiuba.algo3.controlador.RevelacionControlador">

    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>

    <Label text="Revelación de jugadores">
        <font>
            <Font name="System Bold" size="48.0" />
        </font>
    </Label>

    <Region VBox.vgrow="ALWAYS" />

    <VBox alignment="CENTER" maxHeight="300.0" maxWidth="750.0" prefHeight="300.0" prefWidth="750.0" spacing="40.0" style="-fx-background-color: #4a6572; -fx-border-color: black; -fx-border-width: 3; -fx-background-radius: 5; -fx-border-radius: 5;">

        <Label fx:id="lblNombre" text="#NombreJugador_i" textFill="BLACK">
            <font><Font name="System Bold" size="36.0" /></font>
        </Label>

        <Label fx:id="lblRol" text="ROL">
            <font><Font name="System Bold" size="55.0" /></font>
        </Label>

    </VBox>

    <HBox alignment="CENTER" spacing="10.0">
        <Button fx:id="btnAnterior" mnemonicParsing="false" onAction="#manejarAnterior" prefHeight="40.0" prefWidth="60.0" style="-fx-background-color: #7b8d93; -fx-border-color: black; -fx-border-width: 2;" text="&lt;">
            <font><Font name="System Bold" size="18.0" /></font>
        </Button>
        <Button fx:id="btnSiguiente" mnemonicParsing="false" onAction="#manejarSiguiente" prefHeight="40.0" prefWidth="60.0" style="-fx-background-color: #7b8d93; -fx-border-color: black; -fx-border-width: 2;" text="&gt;">
            <font><Font name="System Bold" size="18.0" /></font>
        </Button>
    </HBox>

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="BOTTOM_LEFT" spacing="20.0">
        <Button mnemonicParsing="false" onAction="#manejarBotonSalir" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #fca311; -fx-border-color: black; -fx-border-width: 2;" text="SALIR">
            <font><Font name="System Bold" size="16.0" /></font>
        </Button>

        <Region HBox.hgrow="ALWAYS" />

        <ImageView fitHeight="60.0" fitWidth="120.0" preserveRatio="true">
            <image>
                <Image url="@/imagenes/logo_fiuba.png" />
            </image>
        </ImageView>
    </HBox>
</VBox>